# Copiar este archivo a .env y completar con las credenciales reales.
# NUNCA subir el archivo .env (con valores reales) al repositorio.

# URL del proyecto de Supabase (Project Settings → API → Project URL)
SUPABASE_URL=

# Publishable key de Supabase (Project Settings → API → Publishable key)
SUPABASE_KEY=

# Cadena de conexión directa a Postgres (Project Settings → Database → Connection string)
DATABASE_URL=
